# ─────────────────────────────────────────────────────────────────────────────
# Plugin: template  (plugins/template/)
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to your project root .env and fill in the values.
# Variables here are read by the plugin at startup (server boot).

# Optional: API key for external services called by this plugin
# MY_PLUGIN_API_KEY=

# Optional: base URL for external webhooks
# MY_PLUGIN_WEBHOOK_URL=

# Optional: enable debug logging for this plugin
# MY_PLUGIN_DEBUG=false
