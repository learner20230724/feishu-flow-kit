              "mode": "raw",
              "raw": "{\n    \"challenge\": \"\",\n    \"encrypt\": \"\",\n    \"type\": \"im.message.receive_v1\",\n    \"schema\": \"2.0\",\n    \"header\": {\n        \"app_id\": \"{{app_id}}\",\n        \"tenant_key\": \"Default\",\n        \"event_id\": \"{{$guid}}\",\n        \"create_time\": \"2026-04-04T15:00:00+0000\",\n        \"event_type\": \"im.message.receive_v1\"\n    },\n    \"event\": {\n        \"sender\": {\n            \"sender_id\": { \"open_id\": \"ou_xxx\", \"union_id\": \"on_xxx\", \"user_id\": \"u_xxx\" },\n            \"sender_type\": \"user\",\n            \"tenant_key\": \"Default\"\n        },\n        \"message\": {\n            \"message_id\": \"om_xxx\",\n            \"root_id\": \"\",\n            \"parent_id\": \"\",\n            \"create_time\": \"1709566200000\",\n            \"chat_id\": \"oc_xxx\",\n            \"chat_type\": \"p2p\",\n            \"message_type\": \"text\",\n            \"content\": \"{\\\"text\\\":\\\"hello\\\"}\"\n        }\n    }\n}"
            },
            "description": "Simulates an incoming Feishu message event. Sends to the bot's /webhook endpoint. Message content is `\"hello\"` — bot should reply with a greeting. Use the **Get Tenant Access Token** request first if testing auth-dependent features."
          },
