            "method": "POST",
            "description": "Feishu URL verification handshake. Bot responds with {\"challenge\": \"...\"}. Send a POST with JSON body containing type=\"url_verification\" and challenge string. Server returns 405 if method is not POST.",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"url_verification\",\n  \"challenge\": \"test_challenge_string\",\n  \"header\": {\n    \"tenant_key\": \"test_tenant\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
