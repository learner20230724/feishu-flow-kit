    {
      "name": "🔑 Feishu API (Auth Required)",
      "item": [
        {
          "name": "Send Message (Reply)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const baseUrl = pm.environment.get('feishu_api_base') || 'https://open.feishu.cn';",
                  "const appId = pm.environment.get('app_id');",
                  "const appSecret = pm.environment.get('app_secret');",
                  "",
                  "const getToken = () => pm.sendRequest({",
                  "  url: `${baseUrl}/open-apis/auth/v3/tenant_access_token/internal`,",
                  "  method: 'POST',",
                  "  header: { 'Content-Type': 'application/json' },",
                  "  body: { mode: 'raw', raw: JSON.stringify({ app_id: appId, app_secret: appSecret }) }",
                  "});",
                  "",
                  "getToken().then(resp => {",
                  "  const data = resp.json();",
                  "  if (data.tenant_access_token) pm.environment.set('tenant_access_token', data.tenant_access_token);",
                  "}).catch(console.warn);"
                ]
              }
            }
          ],
          "request": {
            "url": "{{feishu_api_base}}/open-apis/im/v1/messages?receive_id_type=open_id",
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{tenant_access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"receive_id\": \"ou_xxx\",\n    \"msg_type\": \"text\",\n    \"content\": \"{\\\"text\\\":\\\"Hello from Feishu Flow Kit! 🚀\\\"}\"\n}"
            },
            "description": "Sends a message via Feishu IM API. Requires valid tenant_access_token (auto-refreshed by pre-request script). Replace `receive_id` with a real Open ID."
          },
          "response": []
