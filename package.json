{
  "name": "feishu-flow-kit",
  "version": "1.0.3",
  "description": "Local-first starter kit for practical Feishu automations and AI workflows.",
  "type": "module",
  "keywords": [
    "feishu",
    "lark",
    "automation",
    "typescript",
    "workflow",
    "webhook",
    "ai-workflow",
    "starter-kit"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/learner20230724/feishu-flow-kit.git"
  },
  "homepage": "https://github.com/learner20230724/feishu-flow-kit#readme",
  "bugs": {
    "url": "https://github.com/learner20230724/feishu-flow-kit/issues"
  },
  "license": "MIT",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "table:mapping-draft": "node ./scripts/generate-table-mapping-env.mjs",
    "table:normalize-feishu-fields": "node ./scripts/normalize-feishu-table-fields.mjs",
    "table:extract-select-option-review": "node ./scripts/extract-select-option-review.mjs",
    "table:validate-select-option-override": "node ./scripts/validate-select-option-override.mjs",
    "table:validate-mapping-config": "node ./scripts/validate-table-mapping-config.mjs",
    "docs:export-svg-png": "node ./scripts/export-svg-png.mjs",
    "docs:export-assets": "node ./scripts/export-doc-assets.mjs",
    "verify:table-schema-handoff": "node ./scripts/verify-table-schema-handoff.mjs",
    "verify:release": "bash ./scripts/verify-release-ready.sh"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
