# Production environment variables for feishu-flow-kit + Traefik stack
# Copy this file to .env.production and fill in your values.
# NEVER commit .env.production to version control.

# ── Feishu credentials ────────────────────────────────────────────────────────
#
# Single-app mode: set FEISHU_APP_ID / FEISHU_APP_SECRET below.
# Multi-tenant mode: comment out FEISHU_APP_ID/FEISHU_APP_SECRET and set
# FEISHU_TENANTS as a JSON array (example below).
#
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_TENANT_KEY=tenant_key_from_feishu_open_platform

# FEISHU_TENANTS='[
#   {
#     "tenantKey": "tenant_alice",
#     "appId": "cli_aaaaa",
#     "appSecret": "secret_a",
#     "botName": "Alice Bot",
#     "enableOutboundReply": true,
#     "enableTableCreate": true,
#     "bitableAppToken": "xxx",
#     "bitableTableId": "yyy"
#   },
#   {
#     "tenantKey": "tenant_bob",
#     "appId": "cli_bbbbb",
#     "appSecret": "secret_b",
#     "botName": "Bob Bot",
#     "enableOutboundReply": false,
#     "enableDocCreate": true
#   }
# ]'

FEISHU_VERIFICATION_TOKEN=your_verification_token
FEISHU_ENCRYPT_KEY=

# ── Outbound feature flags ─────────────────────────────────────────────────────
# Set to true once your Feishu app has outbound reply permission enabled.
FEISHU_ENABLE_OUTBOUND_REPLY=false
FEISHU_ENABLE_DOC_CREATE=false
FEISHU_ENABLE_TABLE_CREATE=false

# ── Webhook URL — set by your Traefik public FQDN ─────────────────────────────
# The bot container reads FEISHU_WEBHOOK_URL from docker-compose.yml directly.
# Fill in your VPS domain/IP below so docker-compose.yml can reference it.
VPS_FQDN=your-vps.example.com

# ── Let's Encrypt ─────────────────────────────────────────────────────────────
# Email address for certificate expiry notices from Let's Encrypt.
ACME_EMAIL=admin@your-vps.example.com
