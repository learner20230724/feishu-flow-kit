# ============================================================
# feishu-flow-kit — Environment variables
# ============================================================
#
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Variables marked [required] must be set for real Feishu mode.
# All variables are optional when FEISHU_MOCK_MODE=true (default).
#
# ─────────────────────────────────────────────────────────────

# ── Feishu app credentials [required for real mode] ─────────────────────────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BOT_NAME=feishu-flow-kit

# Webhook secret (from Feishu Open Platform → Event Subscription → Encryption Key)
# [required] in production; leave empty to disable signature verification (dev only)
FEISHU_WEBHOOK_SECRET=

# Public-facing URL of this container (used for Feishu webhook registration)
# Example: https://your-bot.example.com
FEISHU_WEBHOOK_URL=

# Port the webhook server listens on inside the container
FEISHU_WEBHOOK_PORT=8787

# ── Feature toggles ────────────────────────────────────────────────────────────
# Set to false and fill in Feishu credentials above for a real bot
FEISHU_MOCK_MODE=true

# Path (inside container) to the mock event JSON file to replay
FEISHU_MOCK_EVENT_PATH=examples/mock-message-event.json

# Enable 回复卡片 (outbound reply via Feishu messaging API)
FEISHU_ENABLE_OUTBOUND_REPLY=false

# Enable Feishu Doc creation (via Feishu Docs API)
FEISHU_ENABLE_DOC_CREATE=false

# Enable Bitable table record creation (via Feishu Bitable API)
FEISHU_ENABLE_TABLE_CREATE=false

# ── Feishu Bitable ────────────────────────────────────────────────────────────
# App token and table ID from your Bitable (required when FEISHU_ENABLE_TABLE_CREATE=true)
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=

# Custom Bitable field names (match these to your actual table schema)
FEISHU_BITABLE_TITLE_FIELD_NAME=Title
FEISHU_BITABLE_LIST_FIELD_NAME=List
FEISHU_BITABLE_DETAILS_FIELD_NAME=Details
FEISHU_BITABLE_OWNER_FIELD_NAME=Owner
FEISHU_BITABLE_ESTIMATE_FIELD_NAME=Estimate
FEISHU_BITABLE_DUE_FIELD_NAME=Due
FEISHU_BITABLE_DONE_FIELD_NAME=Done
FEISHU_BITABLE_ATTACHMENT_FIELD_NAME=Attachment
FEISHU_BITABLE_LINKED_RECORDS_FIELD_NAME=LinkedRecords
FEISHU_BITABLE_SOURCE_COMMAND_FIELD_NAME=SourceCommand

# Bitable field type modes (text | single_select | multi_select | user | number | date | datetime | checkbox | attachment | linked_record)
FEISHU_BITABLE_LIST_FIELD_MODE=text
FEISHU_BITABLE_OWNER_FIELD_MODE=text
FEISHU_BITABLE_ESTIMATE_FIELD_MODE=text
FEISHU_BITABLE_DUE_FIELD_MODE=text
FEISHU_BITABLE_DONE_FIELD_MODE=text
FEISHU_BITABLE_ATTACHMENT_FIELD_MODE=text
FEISHU_BITABLE_LINK_FIELD_MODE=text

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
