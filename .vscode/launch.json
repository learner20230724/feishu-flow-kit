{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: Webhook Server",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "env": {
        "NODE_ENV": "development"
      },
      "restart": true,
      "resolveSourceMapLocations": [
        "${workspaceFolder}/src/**",
        "${workspaceFolder}/node_modules/**"
      ],
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug: Current Test File",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["test"],
      "env": {
        "NODE_ENV": "test"
      },
      "resolveSourceMapLocations": [
        "${workspaceFolder}/src/**",
        "${workspaceFolder}/node_modules/**"
      ],
      "skipFiles": ["<node_internals>/**"],
      "preLaunchTask": null
    },
    {
      "name": "Debug: Webhook with Mock Event",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "env": {
        "NODE_ENV": "development",
        "FEISHU_MOCK_MODE": "true"
      },
      "resolveSourceMapLocations": [
        "${workspaceFolder}/src/**",
        "${workspaceFolder}/node_modules/**"
      ],
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Debug Server + Mock Event",
      "configurations": ["Debug: Webhook Server"],
      "stopAll": true
    }
  ]
}
